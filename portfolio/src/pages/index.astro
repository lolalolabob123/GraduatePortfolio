---
import Layout from '../layouts/Layout.astro'

const projects = [
	{
	title: "TwinTiles Puzzle Game",
	description: "A mobile logic puzzle game built with React Native and Expo. Players must solve grids by adhering to strict layput rules, requiring custom validation algorithms.",
	tech: ["React Native", "Expo", "Typescript"],
	highlights: [
      "Engineered custom validation algorithms enforcing strict layout rules: no more than two tiles of the same color can sit directly next to each other, including those placed by the player.",
      "Utilized persistent local storage to save game states, levels, and user progress across sessions.",
      "Built a highly responsive, tactile mobile layout optimized for different screen ratios using Expo.",
    ],
	github: "https://github.com/lolalolabob123/PuzzleGameProject",
	demo: "#"
	},
	{
    title: "Kanban Project Management App",
    description: "A full-stack workflow application inspired by Trello that allows users to create boards, manage tasks, and organize custom workflows.",
    tech: ["React", "TypeScript", "Express", "MongoDB", "Tailwind CSS"],
    highlights: [
      "Implemented a seamless drag-and-drop workflow for interactive task management.",
      "Built a robust REST API to handle seamless CRUD updates to tasks, columns, and boards.",
      "Backed by a persistent MongoDB database to ensure user workflows are saved securely."
    ],
    github: "https://github.com/yourusername/kanban-app",
    demo: "https://your-kanban-demo.com"
  },
]
---

<Layout>
	<main class="max-w-4xl mx-auto px-6 py-16 md:py-24 space-y-24">

	<!-- Hero Section -->
	<section class="min-h-[70vh] flex flex-col justify-center space-y-6">
		<h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-tight">
			Frontend Developer building fast, accessible, and interactive web experiences.
		</h1>
		<p class="text-lg md:text-xl text-slate-400 max-w-2xl leading-relaxed">
			Recent Creative Web Technologies graduate with a strong foundation in modern frontend development. I enjoy building responsive, accessible, and high-performance websites using modern JavaScript frameworks while writing clean, maintainable code.
      	</p>
	  	<div class="flex flex-wrap gap-4 pt-4">
	  		<a href="#projects" class="px-6 py-3 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-500 transition-colors shadow-md cursor-pointer">
			View projects
			</a>
			<a href="https://github.com/lolalolabob123" target="_blank" rel="noopener noreferrer" class="px-6 py-3 bg-slate-900 border border-slate-800 text-slate-200 font-medium rounded-lg hover:bg-slate-850 hover:border-slate-700 transition-all cursor-pointer">
			Github
			</a>
		</div>
	</section>

	<!-- About Me Section -->
    <section id="about" class="grid md:grid-cols-3 gap-8 pt-8 border-t border-slate-900 scroll-mt-24">
      <h2 class="text-2xl font-bold text-white">About Me</h2>
      <div class="md:col-span-2 space-y-6 text-slate-300 leading-relaxed">
        <p class="text-lg text-white font-medium">Hi, I'm Callum.</p>
        <p>
          I'm a frontend developer with a background in Creative Web Technologies, combining an understanding of both design and development to create user-focused web applications.
        </p>
        <p>
          Throughout my degree, I developed a strong appreciation for building interfaces that not only look polished but are also responsive, accessible, and easy to use. I enjoy turning ideas and designs into clean, semantic code while focusing on maintainability, performance, and user experience.
        </p>
        <p>
          I work primarily with <strong class="text-indigo-400">JavaScript, TypeScript, React, and Next.js</strong>, and I'm always looking to expand my knowledge by building projects that challenge me to learn new technologies and improve my problem-solving skills.
        </p>
        <p>
          As a developer, I value writing code that is easy to understand, scalable, and accessible to all users. Whether I'm creating reusable React components, improving application performance, or refining small UI interactions, I enjoy finding simple solutions to complex problems.
        </p>
        <p>
          I'm currently seeking opportunities as a <strong class="text-indigo-400">Junior Frontend Developer</strong>, where I can continue learning from experienced developers while contributing to meaningful projects.
        </p>
        <p class="text-slate-400 italic">
          Outside of development, I enjoy gaming, which helps me stay creative and curious outside of programming.
        </p>
      </div>
    </section>

	<!-- Technical Skills Section -->
    <section id="skills" class="grid md:grid-cols-3 gap-8 pt-8 border-t border-slate-900 scroll-mt-24">
      <div>
        <h2 class="text-2xl font-bold text-white sticky top-8">Skills & Technologies</h2>
        <p class="text-slate-400 mt-2 text-sm leading-relaxed">
          My technical toolkit focused on modern frontend engineering, clean system architecture, and inclusive user experiences.
        </p>
      </div>
      
      <div class="md:col-span-2 space-y-12">
        <!-- Part 1: Core Competency Cards -->
        <div class="grid sm:grid-cols-2 gap-6">
          
          <div class="p-6 rounded-xl bg-slate-900/40 border border-slate-900 hover:border-slate-800 transition-colors">
            <h3 class="text-lg font-semibold text-white mb-2">Frontend Development</h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              Building responsive, component-based user interfaces with React and Next.js. I focus on modular, reusable structures and strict state management.
            </p>
          </div>

          <div class="p-6 rounded-xl bg-slate-900/40 border border-slate-900 hover:border-slate-800 transition-colors">
            <h3 class="text-lg font-semibold text-white mb-2">Styling & UI</h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              Translating layout grids from Figma to CSS. I heavily rely on Tailwind CSS, Flexbox, and Grid to ensure fluid responsiveness across all viewports.
            </p>
          </div>

          <div class="p-6 rounded-xl bg-slate-900/40 border border-slate-900 hover:border-slate-800 transition-colors">
            <h3 class="text-lg font-semibold text-white mb-2">Web Accessibility</h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              Enforcing semantic HTML, screen-reader support, keyboard navigability, and WCAG accessibility standards from the first line of code.
            </p>
          </div>

          <div class="p-6 rounded-xl bg-slate-900/40 border border-slate-900 hover:border-slate-800 transition-colors">
            <h3 class="text-lg font-semibold text-white mb-2">Performance & SEO</h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              Optimizing bundle sizes, prioritizing asset loading, minimizing state redraws, and tracking Core Web Vitals to keep web apps feeling native.
            </p>
          </div>

          <div class="p-6 rounded-xl bg-slate-900/40 border border-slate-900 hover:border-slate-800 transition-colors sm:col-span-2">
            <h3 class="text-lg font-semibold text-white mb-2">Backend & APIs</h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              Experienced in writing lightweight backend code with Node.js and Express. I design RESTful APIs and integrate secure MongoDB architectures to feed data directly to frontend client applications.
            </p>
          </div>

        </div>

        <!-- Part 2: The Tech Stack Pill Grid -->
        <div class="space-y-6 pt-6 border-t border-slate-900/60">
          
          <!-- Languages -->
          <div class="space-y-3">
            <h4 class="text-xs font-semibold uppercase tracking-wider text-indigo-400">Languages</h4>
            <div class="flex flex-wrap gap-2">
              {['HTML5', 'CSS3', 'JavaScript (ES6+)', 'TypeScript'].map((tech) => (
                <span class="px-3 py-1.5 text-xs font-medium text-slate-300 bg-slate-900/80 border border-slate-800/85 rounded-lg hover-glow transition-all cursor-default">
                  {tech}
                </span>
              ))}
            </div>
          </div>

          <!-- Frontend Frameworks -->
          <div class="space-y-3">
            <h4 class="text-xs font-semibold uppercase tracking-wider text-indigo-400">Frontend</h4>
            <div class="flex flex-wrap gap-2">
              {['React', 'Next.js', 'Astro', 'Tailwind CSS', 'Sass'].map((tech) => (
                <span class="px-3 py-1.5 text-xs font-medium text-slate-300 bg-slate-900/80 border border-slate-800/85 rounded-lg hover-glow transition-all cursor-default">
                  {tech}
                </span>
              ))}
            </div>
          </div>

          <!-- Backend -->
          <div class="space-y-3">
            <h4 class="text-xs font-semibold uppercase tracking-wider text-indigo-400">Backend</h4>
            <div class="flex flex-wrap gap-2">
              {['Node.js', 'Express', 'MongoDB', 'REST APIs'].map((tech) => (
                <span class="px-3 py-1.5 text-xs font-medium text-slate-300 bg-slate-900/80 border border-slate-800/85 rounded-lg hover-glow transition-all cursor-default">
                  {tech}
                </span>
              ))}
            </div>
          </div>

          <!-- Dev Tools -->
          <div class="space-y-3">
            <h4 class="text-xs font-semibold uppercase tracking-wider text-indigo-400">Tools</h4>
            <div class="flex flex-wrap gap-2">
              {['Git', 'GitHub', 'Vite', 'VS Code', 'npm', 'Figma', 'Postman'].map((tech) => (
                <span class="px-3 py-1.5 text-xs font-medium text-slate-300 bg-slate-900/80 border border-slate-800/85 rounded-lg hover-glow transition-all cursor-default">
                  {tech}
                </span>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

	<!-- Project Section Placeholder -->
<!-- Projects Section -->
    <section id="projects" class="pt-8 border-t border-slate-900 space-y-12 scroll-mt-24">
      <div>
        <h2 class="text-2xl font-bold text-white">Featured Projects</h2>
        <p class="text-slate-400 mt-2 text-sm max-w-xl">
          A selection of full-stack and interactive projects I built to solve real problems and explore new technologies.
        </p>
      </div>
      
      <div class="space-y-16">
        {projects.map((project) => (
          <div class="group grid md:grid-cols-5 gap-8 p-6 md:p-8 rounded-2xl bg-slate-900/20 border border-slate-900/60 hover:bg-slate-900/40 hover:border-indigo-500/30 transition-all duration-300">
            
            <!-- Left Side: Basic Info & Tech Stack (Takes up 2/5 columns on desktop) -->
            <div class="md:col-span-2 flex flex-col justify-between space-y-6">
              <div class="space-y-3">
                <h3 class="text-xl font-bold text-white group-hover:text-indigo-400 transition-colors">
                  {project.title}
                </h3>
                <p class="text-sm text-slate-400 leading-relaxed">
                  {project.description}
                </p>
              </div>
              
              <!-- Tech Tags -->
              <div class="flex flex-wrap gap-2 pt-2">
                {project.tech.map((t) => (
                  <span class="px-2.5 py-1 text-xs font-medium text-indigo-300 bg-indigo-950/40 border border-indigo-900/50 rounded-md">
                    {t}
                  </span>
                ))}
              </div>
            </div>

            <!-- Right Side: Key Highlights & Links (Takes up 3/5 columns on desktop) -->
            <div class="md:col-span-3 flex flex-col justify-between space-y-6">
              <ul class="space-y-3">
                {project.highlights.map((highlight) => (
                  <li class="flex items-start text-sm text-slate-300 leading-relaxed">
                    <span class="text-indigo-500 mr-2.5 select-none mt-1">✦</span>
                    <span>{highlight}</span>
                  </li>
                ))}
              </ul>

              <!-- Project Action Links -->
              <div class="flex items-center gap-4 pt-4 text-sm font-semibold border-t border-slate-900/60">
                <a 
                  href={project.github} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="flex items-center gap-1.5 text-slate-300 hover:text-white transition-colors cursor-pointer"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.53 1.032 1.53 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                  </svg>
                  Source Code
                </a>
                
                {project.demo !== "#" && (
                  <a 
                    href={project.demo} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="flex items-center gap-1.5 text-indigo-400 hover:text-indigo-300 transition-colors cursor-pointer"
                  >
                    Live Demo
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"></path>
                    </svg>
                  </a>
                )}
              </div>
            </div>

          </div>
        ))}
      </div>
    </section>
	</main>
</Layout>